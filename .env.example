# ---------- App ----------
NEXTAUTH_SECRET=replace-with-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:3000

# AES-GCM 32-byte hex key used to encrypt OAuth tokens at rest in Postgres.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# ---------- Vercel Postgres ----------
# Vercel injects POSTGRES_URL automatically in production.
# For local dev, paste the connection string from `vercel env pull`.
POSTGRES_URL=

# ---------- Vercel Blob ----------
BLOB_READ_WRITE_TOKEN=

# ---------- OpenAI Codex OAuth (shared admin token model) ----------
# Bootstrap tokens captured locally via the OpenClaw CLI on Jaret's machine.
# After first deploy these live in the oauth_tokens table and refresh automatically;
# these env vars are only the seed.
OPENAI_OAUTH_BOOTSTRAP_ACCESS=
OPENAI_OAUTH_BOOTSTRAP_REFRESH=
OPENAI_OAUTH_BOOTSTRAP_EXPIRES=
OPENAI_OAUTH_BOOTSTRAP_ACCOUNT_ID=

# ---------- Model routing ----------
MODEL_PRIMARY=openai/gpt-5.5
MODEL_FALLBACK=openai/gpt-5.4-mini
EMBEDDING_MODEL=text-embedding-3-large

# ---------- Cron secret (Vercel Cron sends this in the header) ----------
CRON_SECRET=replace-with-openssl-rand-hex-32
